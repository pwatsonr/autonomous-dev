{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomous-dev.local/schemas/events/verification_false_negative_corrected.schema.json",
  "title": "verification_false_negative_corrected",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "timestamp", "type", "request_id", "phase", "evidence"],
  "properties": {
    "schema_version": {"const": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "type": {"const": "verification_false_negative_corrected"},
    "request_id": {"type": "string", "pattern": "^REQ-[0-9]{6}$"},
    "phase": {"type": "string"},
    "failure_mode": {"type": ["string", "null"], "pattern": "^F[1-9]$"},
    "remediation_planned": {"type": ["string", "null"]},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["artifact_path", "artifact_mtime", "failures", "original_status", "original_status_reason", "corrected_at"],
      "properties": {
        "artifact_path": {"type": "string"},
        "artifact_mtime": {"type": "string"},
        "failures": {"type": "integer"},
        "original_status": {"type": "string"},
        "original_status_reason": {"type": "string"},
        "corrected_at": {"type": "string"}
      }
    }
  }
}
