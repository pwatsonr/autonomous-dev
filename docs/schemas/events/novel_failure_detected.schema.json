{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomous-dev.local/schemas/events/novel_failure_detected.schema.json",
  "title": "novel_failure_detected",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "timestamp", "type", "request_id", "phase", "evidence"],
  "properties": {
    "schema_version": {"const": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "type": {"const": "novel_failure_detected"},
    "request_id": {"type": "string", "pattern": "^REQ-[0-9]{6}$"},
    "phase": {"type": "string"},
    "failure_mode": {"type": ["string", "null"], "pattern": "^F[1-9]$"},
    "remediation_planned": {"type": ["string", "null"]},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["observed_status", "state_parseable", "missing_artifact_paths"],
      "properties": {
        "observed_status": {"type": "string"},
        "state_parseable": {"type": "boolean"},
        "missing_artifact_paths": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
