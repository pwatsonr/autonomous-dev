{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomous-dev.local/schemas/events/reviewer_timeout_repeated.schema.json",
  "title": "reviewer_timeout_repeated",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "timestamp", "type", "request_id", "phase", "evidence"],
  "properties": {
    "schema_version": {"const": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "type": {"const": "reviewer_timeout_repeated"},
    "request_id": {"type": "string", "pattern": "^REQ-[0-9]{6}$"},
    "phase": {"type": "string"},
    "failure_mode": {"type": ["string", "null"], "pattern": "^F[1-9]$"},
    "remediation_planned": {"type": ["string", "null"]},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "timeout_count", "current_timeout_seconds"],
      "properties": {
        "reviewer": {"type": "string"},
        "timeout_count": {"type": "integer"},
        "current_timeout_seconds": {"type": "integer"}
      }
    }
  }
}
