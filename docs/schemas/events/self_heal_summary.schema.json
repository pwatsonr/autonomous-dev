{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomous-dev.local/schemas/events/self_heal_summary.schema.json",
  "title": "self_heal_summary",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "timestamp", "type", "request_id", "phase", "evidence"],
  "properties": {
    "schema_version": {"const": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "type": {"const": "self_heal_summary"},
    "request_id": {"type": "string", "pattern": "^REQ-[0-9]{6}$"},
    "phase": {"type": "string"},
    "failure_mode": {"type": ["string", "null"], "pattern": "^F[1-9]$"},
    "remediation_planned": {"type": ["string", "null"]},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["detections", "remediations_succeeded", "remediations_declined"],
      "properties": {
        "detections": {"type": "object"},
        "remediations_succeeded": {"type": "object"},
        "remediations_declined": {"type": "object"},
        "terminal_status": {"type": ["string", "null"]}
      }
    }
  }
}
