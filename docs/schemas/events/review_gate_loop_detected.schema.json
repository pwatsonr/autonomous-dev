{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomous-dev.local/schemas/events/review_gate_loop_detected.schema.json",
  "title": "review_gate_loop_detected",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "timestamp", "type", "request_id", "phase", "evidence"],
  "properties": {
    "schema_version": {"const": 1},
    "timestamp": {"type": "string", "format": "date-time"},
    "type": {"const": "review_gate_loop_detected"},
    "request_id": {"type": "string", "pattern": "^REQ-[0-9]{6}$"},
    "phase": {"type": "string"},
    "failure_mode": {"type": ["string", "null"], "pattern": "^F[1-9]$"},
    "remediation_planned": {"type": ["string", "null"]},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewer", "fingerprint", "count", "last_seen_at"],
      "properties": {
        "reviewer": {"type": "string"},
        "fingerprint": {"type": "string"},
        "count": {"type": "integer"},
        "last_seen_at": {"type": "string"}
      }
    }
  }
}
