{
  "name": "autonomous-dev-deploy-aws",
  "version": "0.1.0",
  "description": "AWS (ECR + ECS Fargate) deployment backend for autonomous-dev.",
  "author": "autonomous-dev contributors",
  "extends": ["autonomous-dev"],
  "deployment_backend": {
    "name": "aws",
    "regions_supported": [
      "us-east-1",
      "us-east-2",
      "us-west-1",
      "us-west-2",
      "eu-west-1",
      "eu-west-2",
      "eu-central-1",
      "ap-northeast-1",
      "ap-southeast-1",
      "ap-southeast-2"
    ],
    "services_supported": ["ecs-fargate", "ecr", "alb"],
    "credential_provider": "credential-proxy"
  }
}
