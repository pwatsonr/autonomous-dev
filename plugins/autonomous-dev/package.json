{
  "name": "autonomous-dev",
  "version": "0.1.0",
  "private": true,
  "description": "Autonomous development pipeline plugin for Claude Code",
  "type": "module",
  "bin": {
    "reload-plugins": "./bin/reload-plugins.js"
  },
  "scripts": {
    "prepare": "node -e \"try{require('fs').chmodSync('./bin/reload-plugins.js', 0o755)}catch{}\"",
    "test": "jest --passWithNoTests",
    "test:slack": "jest tests/adapters/slack-setup.test.ts",
    "test:cli": "jest intake/adapters/cli_adapter.test.ts",
    "test:bats": "bats tests/bats/",
    "test:ci-schema": "bats ../../tests/ci/test_plugin_schema.bats",
    "test:perf": "ts-node --transpile-only --compiler-options '{\"module\":\"commonjs\"}' tests/perf/test-validation-pipeline.bench.ts",
    "test:cred-proxy": "jest tests/cred-proxy",
    "test:kind": "RUN_KIND_TESTS=1 jest tests/integration/test-cred-proxy-scope.test.ts --runInBand",
    "lint:no-tbd-shas": "bash ../../scripts/lint/no-tbd-shas.sh",
    "build:cli": "bun build intake/adapters/cli_adapter.ts --outfile=intake/adapters/cli_adapter.js --target=node --external better-sqlite3 --external \"@aws-sdk/*\" --external \"@azure/*\" --external \"@google-cloud/*\" --external \"@kubernetes/*\" --external \"@slack/*\" --external discord.js --external express"
  },
  "dependencies": {
    "@aws-sdk/client-sts": "^3.1041.0",
    "@azure/arm-authorization": "^9.0.0",
    "@azure/identity": "^4.13.1",
    "@google-cloud/iam-credentials": "^4.2.2",
    "@kubernetes/client-node": "^1.4.0",
    "@slack/socket-mode": "^2.0.0",
    "@slack/web-api": "^7.0.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^2.1.1",
    "better-sqlite3": "^12.9.0",
    "commander": "^11.1.0",
    "discord.js": "^14.26.3",
    "express": "^4.21.0",
    "js-yaml": "^3.14.1",
    "picomatch": "^4.0.4",
    "semver": "^7.7.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^3.12.10",
    "@types/node": "^22.0.0",
    "@types/supertest": "^6.0.0",
    "fast-check": "^4.7.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.0",
    "yaml": "^2.6.0"
  }
}
