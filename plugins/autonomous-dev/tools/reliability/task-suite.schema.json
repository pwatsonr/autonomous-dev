{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://autonomous-dev/tools/reliability/task-suite.schema.json",
  "title": "ReliabilityTaskSuite",
  "type": "object",
  "required": ["tasks"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "integer" },
    "description": { "type": "string" },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "sizeClass", "expectedTerminalPhase"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
          "description": { "type": "string", "minLength": 1 },
          "sizeClass": {
            "type": "string",
            "enum": ["trivial-docs", "small", "standard", "large"]
          },
          "expectedTerminalPhase": { "type": "string", "const": "done" },
          "timeoutMs": { "type": "integer", "minimum": 1, "description": "Per-task poll timeout in ms (#552); falls back to the batch default if unset." }
        }
      }
    }
  }
}
