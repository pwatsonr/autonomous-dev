{
  "id": "code-fixer",
  "name": "Code Fixer (fixture)",
  "version": "0.0.1",
  "hooks": [
    {
      "id": "fix",
      "hook_point": "review-post-score",
      "entry_point": "./code-fixer.js",
      "priority": 50,
      "failure_mode": "warn"
    }
  ],
  "produces": [
    {
      "artifact_type": "code-patches",
      "schema_version": "1.0",
      "format": "json",
      "requires_approval": true,
      "on_failure": "block",
      "description": "FIXTURE: emits one placeholder patch per finding. SPEC-022-2-03."
    }
  ],
  "consumes": [
    {
      "artifact_type": "security-findings",
      "schema_version": "^1.0",
      "on_failure": "warn",
      "description": "FIXTURE: consumes security-findings; warns if upstream fails."
    }
  ]
}
