{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autonomous-dev.local/test-fixtures/code-patches/1.0.json",
  "title": "TestCodePatches 1.0",
  "type": "object",
  "additionalProperties": false,
  "required": ["patches"],
  "properties": {
    "patches": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["file", "hunks"],
        "properties": {
          "file": { "type": "string", "minLength": 1 },
          "hunks": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
