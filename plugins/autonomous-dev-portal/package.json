{
  "name": "@autonomous-dev/portal",
  "version": "0.1.0",
  "private": true,
  "description": "Local web portal for monitoring autonomous-dev requests, runs, and audit logs.",
  "type": "module",
  "engines": {
    "bun": ">=1.0.0"
  },
  "scripts": {
    "start": "bun run server/server.ts",
    "portal:cypress": "PORTAL_PORT=19283 AUTONOMOUS_DEV_STATE_DIR=/tmp/cypress-state PORTAL_TEST_MODE=1 bun run server/server.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint server/ tests/",
    "test": "bun test",
    "test:visual": "npx playwright test tests/visual-regression/design-system.spec.ts",
    "gen:visual-goldens": "UPDATE_GOLDEN=1 npx playwright test tests/visual-regression/design-system.spec.ts --project=golden-gen",
    "cypress:ci": "start-server-and-test portal:cypress http://localhost:19283 'npx cypress run'",
    "cypress:open": "start-server-and-test portal:cypress http://localhost:19283 'npx cypress open'"
  },
  "dependencies": {
    "dompurify": "~3.0.5",
    "hono": "^3.12.0",
    "jsdom": "~22.1.0",
    "marked": "~5.1.2"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/dompurify": "~3.0.0",
    "@types/jsdom": "~21.1.0",
    "@types/marked": "~5.0.0",
    "@types/node": "^22.0.0",
    "cypress": "^15.15.0",
    "start-server-and-test": "^3.0.5",
    "typescript": "^5.3.0"
  }
}
